# Copy this file to .env and fill in your Supabase project values.

# Required for Supabase writes.
SUPABASE_URL=https://your-project-ref.supabase.co

# Preferred for this server-side scraper. Do not expose this key in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional fallback if you do not want to use the service role key.
# This only works if your table permissions allow inserts and updates.
SUPABASE_ANON_KEY=your-anon-key

# Optional overrides.
SUPABASE_DB_SCHEMA=public
SUPABASE_ARTICLES_TABLE=roblox_game_code_articles
SUPABASE_CODES_TABLE=roblox_game_codes
SUPABASE_LETROSO_ANSWERS_TABLE=letroso_answers

# Required only when pushing rendered codes into WordPress.
WORDPRESS_USERNAME=your-wordpress-username
WORDPRESS_APPLICATION_PASSWORD=your-wordpress-application-password

# Optional marker overrides for the section that should be replaced.
WORDPRESS_CODES_MARKER_START=<!-- TN_CODES_START -->
WORDPRESS_CODES_MARKER_END=<!-- TN_CODES_END -->
WORDPRESS_EXPIRED_CODES_MARKER_START=<!-- TN_EXPIRED_CODES_START -->
WORDPRESS_EXPIRED_CODES_MARKER_END=<!-- TN_EXPIRED_CODES_END -->
WORDPRESS_CODES_UPDATE_MARKER_START=<!-- TN_CODES_UPDATE_START -->
WORDPRESS_CODES_UPDATE_MARKER_END=<!-- TN_CODES_UPDATE_END -->
WORDPRESS_LETROSO_ARTICLE_URL=https://www.technerdiness.com/puzzle/letroso-answers-today/
WORDPRESS_LETROSO_MARKER_START=<!-- TN_LETROSO_ANSWER_START -->
WORDPRESS_LETROSO_MARKER_END=<!-- TN_LETROSO_ANSWER_END -->
WORDPRESS_LETROSO_HISTORY_MARKER_START=<!-- TN_LETROSO_HISTORY_START -->
WORDPRESS_LETROSO_HISTORY_MARKER_END=<!-- TN_LETROSO_HISTORY_END -->
WORDPRESS_LETROSO_CURRENT_DATE_MARKER_START=<!-- TN_LETROSO_CURRENT_DATE_START -->
WORDPRESS_LETROSO_CURRENT_DATE_MARKER_END=<!-- TN_LETROSO_CURRENT_DATE_END -->
WORDPRESS_UPDATE_TIMEZONE=Asia/Kolkata
