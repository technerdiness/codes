# Copy this file to .env and fill in your Supabase project values.

# Required for Supabase writes.
SUPABASE_URL=https://your-project-ref.supabase.co

# Preferred for this server-side scraper. Do not expose this key in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional fallback if you do not want to use the service role key.
# This only works if your table permissions allow inserts and updates.
SUPABASE_ANON_KEY=your-anon-key

# Optional overrides.
SUPABASE_DB_SCHEMA=public
SUPABASE_ARTICLES_TABLE=roblox_game_code_articles
SUPABASE_CODES_TABLE=roblox_game_codes
SUPABASE_LETROSO_ANSWERS_TABLE=letroso_answers
SUPABASE_WORDLE_ANSWERS_TABLE=wordle_answers
SUPABASE_CONNECTIONS_ANSWERS_TABLE=connections_answers
SUPABASE_STRANDS_ANSWERS_TABLE=strands_answers

# Required only when pushing rendered codes into WordPress.
WORDPRESS_USERNAME=your-wordpress-username
WORDPRESS_APPLICATION_PASSWORD=your-wordpress-application-password

# Optional marker overrides for the section that should be replaced.
WORDPRESS_CODES_MARKER_START=<!-- TN_CODES_START -->
WORDPRESS_CODES_MARKER_END=<!-- TN_CODES_END -->
WORDPRESS_EXPIRED_CODES_MARKER_START=<!-- TN_EXPIRED_CODES_START -->
WORDPRESS_EXPIRED_CODES_MARKER_END=<!-- TN_EXPIRED_CODES_END -->
WORDPRESS_CODES_UPDATE_MARKER_START=<!-- TN_CODES_UPDATE_START -->
WORDPRESS_CODES_UPDATE_MARKER_END=<!-- TN_CODES_UPDATE_END -->
WORDPRESS_LETROSO_ARTICLE_URL=https://www.technerdiness.com/puzzle/letroso-answers-today/
WORDPRESS_LETROSO_MARKER_START=<!-- TN_LETROSO_ANSWER_START -->
WORDPRESS_LETROSO_MARKER_END=<!-- TN_LETROSO_ANSWER_END -->
WORDPRESS_LETROSO_HISTORY_MARKER_START=<!-- TN_LETROSO_HISTORY_START -->
WORDPRESS_LETROSO_HISTORY_MARKER_END=<!-- TN_LETROSO_HISTORY_END -->
WORDPRESS_LETROSO_CURRENT_DATE_MARKER_START=<!-- TN_LETROSO_CURRENT_DATE_START -->
WORDPRESS_LETROSO_CURRENT_DATE_MARKER_END=<!-- TN_LETROSO_CURRENT_DATE_END -->
WORDPRESS_WORDLE_ARTICLE_URL=https://www.technerdiness.com/puzzle/todays-wordle-hints-answers/
WORDPRESS_WORDLE_MARKER_START=<!-- TN_WORDLE_ANSWER_START -->
WORDPRESS_WORDLE_MARKER_END=<!-- TN_WORDLE_ANSWER_END -->
WORDPRESS_CONNECTIONS_ARTICLE_URL=https://www.technerdiness.com/puzzle/todays-nyt-connections-hints-answers/
WORDPRESS_CONNECTIONS_MARKER_START=<!-- TN_CONNECTIONS_ANSWER_START -->
WORDPRESS_CONNECTIONS_MARKER_END=<!-- TN_CONNECTIONS_ANSWER_END -->
WORDPRESS_CONNECTIONS_CURRENT_DATE_MARKER_START=<!-- TN_CONNECTIONS_CURRENT_DATE_START -->
WORDPRESS_CONNECTIONS_CURRENT_DATE_MARKER_END=<!-- TN_CONNECTIONS_CURRENT_DATE_END -->
WORDPRESS_STRANDS_ARTICLE_URL=https://www.technerdiness.com/puzzle/todays-nyt-strands-hints-answers/
WORDPRESS_STRANDS_SPANGRAM_MARKER_START=<!-- TN_STRANDS_SPANGRAM_START -->
WORDPRESS_STRANDS_SPANGRAM_MARKER_END=<!-- TN_STRANDS_SPANGRAM_END -->
WORDPRESS_STRANDS_THEME_WORDS_MARKER_START=<!-- TN_STRANDS_THEME_WORDS_START -->
WORDPRESS_STRANDS_THEME_WORDS_MARKER_END=<!-- TN_STRANDS_THEME_WORDS_END -->
WORDPRESS_STRANDS_CURRENT_DATE_MARKER_START=<!-- TN_STRANDS_CURRENT_DATE_START -->
WORDPRESS_STRANDS_CURRENT_DATE_MARKER_END=<!-- TN_STRANDS_CURRENT_DATE_END -->
WORDPRESS_STRANDS_CLUE_MARKER_START=<!-- TN_STRANDS_CLUE_START -->
WORDPRESS_STRANDS_CLUE_MARKER_END=<!-- TN_STRANDS_CLUE_END -->
WORDPRESS_UPDATE_TIMEZONE=Asia/Kolkata
CONNECTIONS_TIMEZONE=Asia/Kolkata
STRANDS_TIMEZONE=Asia/Kolkata
WORDLE_TIMEZONE=Asia/Kolkata

# If you deploy the Supabase Edge Function, set these same values as Supabase function secrets.
# The webhook secret also needs a matching Vault secret named nyt_puzzles_sync_webhook_secret.
# Optional for Supabase Edge Function webhook auth when calling sync-nyt-puzzles directly.
NYT_PUZZLES_SYNC_WEBHOOK_SECRET=your-random-long-secret
SYNC_CODES_WEBHOOK_SECRET=your-random-long-secret
SYNC_LETROSO_WEBHOOK_SECRET=your-random-long-secret

# Optional local-only overrides for the Chrome/Playwright Letroso extractor.
LETROSO_CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
LETROSO_CHROME_USER_DATA_DIR=/Users/your-user/Library/Application Support/Google/Chrome
LETROSO_CHROME_PROFILE=Default
LETROSO_CHROME_LANGUAGE=en
LETROSO_CHROME_LOCALE=en-US
LETROSO_CHROME_TIMEZONE=Asia/Kolkata
LETROSO_CHROME_WAIT_MS=30000
