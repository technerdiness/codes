{
  "name": "codes-automations",
  "version": "1.0.0",
  "description": "Automation scripts for scraping game codes and syncing them to Supabase and WordPress.",
  "scripts": {
    "sync:codes": "tsx src/automations/sync-codes.ts",
    "scrape": "tsx src/automations/scrape-beebom.ts",
    "scrape:supabase": "tsx src/automations/scrape-beebom.ts --save",
    "reveal:letroso": "tsx src/automations/reveal-letroso-answer.ts",
    "reveal:letroso:supabase": "tsx src/automations/reveal-letroso-answer.ts --save",
    "typecheck": "tsc -p tsconfig.json",
    "start": "tsx src/automations/scrape-beebom.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
